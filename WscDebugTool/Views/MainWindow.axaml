<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WscDebugTool.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:AvaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="WscDebugTool.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="WscDebugTool">

    <!--<Design.DataContext>
        --><!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) --><!--
        <vm:MainWindowViewModel/>
    </Design.DataContext>-->

	
	<SplitView IsPaneOpen="True"
        DisplayMode="Inline"
        OpenPaneLength="300">
		<SplitView.Pane>
			<Panel>
				<Button Command="{Binding OpenZipFileCommand}" IsVisible="{Binding ShouldShowPickerButton}">Open zip file</Button>

				<ScrollViewer IsVisible="{Binding ArchiveReady}">
					<ItemsControl ItemsSource="{Binding Files}">
						<ItemsControl.ItemTemplate>
							<DataTemplate DataType="vm:XmlFileViewModel">
								<Button Command="{Binding OpenFileCommand}">
									<TextBlock Text="{Binding Name}" />
								</Button>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</ScrollViewer>
			</Panel>
		</SplitView.Pane>
		
		<AvaloniaEdit:TextEditor Name="CodeEditor" Text="Bruh"
                        ShowLineNumbers="True"
                        FontFamily="Cascadia Code,Consolas,Menlo,Monospace"
						HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Visible"/>
	</SplitView>

</Window>
